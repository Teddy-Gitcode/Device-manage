# Copy to .env and fill in real values before running docker-compose up

SECRET_KEY=replace-with-50+-random-chars
DEBUG=true

POSTGRES_DB=devicemonitor
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace-with-strong-password

DATABASE_URL=postgres://admin:replace-with-strong-password@db:5432/devicemonitor
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

SUBNET_PREFIX=192.168
SNMP_COMMUNITY=public
SNMP_TIMEOUT=3.0
SNMP_RETRIES=1

SUPPLY_POLL_INTERVAL_SECONDS=1800
LOG_MIN_INTERVAL_SECONDS=900
POLL_CONCURRENT_LIMIT=10
DISCOVERY_CONCURRENT_LIMIT=20

DJANGO_SETTINGS_MODULE=printer.settings
